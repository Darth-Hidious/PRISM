# PRISM v2.0 Environment Configuration
# Copy to .env and fill in your API keys.

# --- LLM Providers (at least one required) ---

# OpenAI
# OPENAI_API_KEY=your-api-key-here

# Anthropic
# ANTHROPIC_API_KEY=your-api-key-here

# Google Vertex AI
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# OpenRouter (access to 200+ models with a single key)
# OPENROUTER_API_KEY=your-api-key-here

# --- MARC27 chat model (two separate axes) ---
# The same model can be served by more than one provider at different
# prices and billing routes (e.g. claude-sonnet-5 direct from Anthropic
# vs via OpenRouter). LLM_PROVIDER picks the serving provider,
# LLM_MODEL picks the model; the pair is resolved against the platform
# model catalog. Leave both unset to use the platform's default model.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-5

# --- Data Sources ---

# Materials Project API key (optional, for enriched properties)
# MATERIALS_PROJECT_API_KEY=your-mp-api-key-here
